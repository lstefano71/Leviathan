<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="using:Leviathan.GUI.Widgets"
        x:Class="Leviathan.GUI.Views.MainWindow"
        x:CompileBindings="True"
        Title="Leviathan"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" x:Name="MainMenu">
            <MenuItem Header="_File" x:Name="FileMenu">
                <MenuItem Header="_Open... (Ctrl+O)" x:Name="MenuOpen" HotKey="Ctrl+O" />
                <MenuItem Header="_Close (Ctrl+W)" x:Name="MenuClose" HotKey="Ctrl+W" />
                <MenuItem Header="_Save (Ctrl+S)" x:Name="MenuSave" HotKey="Ctrl+S" />
                <MenuItem Header="Save _As..." x:Name="MenuSaveAs" />
                <Separator />
                <!-- MRU items inserted dynamically -->
                <Separator x:Name="MruSeparator" IsVisible="False" />
                <MenuItem Header="E_xit (Ctrl+Q)" x:Name="MenuExit" HotKey="Ctrl+Q" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Hex View (F5)" x:Name="MenuViewHex" HotKey="F5" />
                <MenuItem Header="_Text View (F6)" x:Name="MenuViewText" HotKey="F6" />
                <MenuItem Header="_CSV View (F7)" x:Name="MenuViewCsv" HotKey="F7" />
                <Separator />
                <MenuItem Header="_Line Wrap" x:Name="MenuWordWrap" />
                <MenuItem Header="Show _Gutter (Ctrl+Shift+G)" x:Name="MenuGutter" HotKey="Ctrl+Shift+G" />
                <MenuItem Header="_Decimal Offsets" x:Name="MenuDecimalOffsets" />
                <MenuItem Header="_Encoding" x:Name="MenuEncoding">
                    <MenuItem Header="UTF-8" x:Name="MenuEncodingUtf8" />
                    <MenuItem Header="UTF-16 LE" x:Name="MenuEncodingUtf16Le" />
                    <MenuItem Header="Windows-1252" x:Name="MenuEncodingWin1252" />
                </MenuItem>
                <MenuItem Header="_Bytes/Row" x:Name="MenuBytesPerRow">
                    <MenuItem Header="Auto" x:Name="MenuBprAuto" />
                    <MenuItem Header="8" x:Name="MenuBpr8" />
                    <MenuItem Header="16" x:Name="MenuBpr16" />
                    <MenuItem Header="24" x:Name="MenuBpr24" />
                    <MenuItem Header="32" x:Name="MenuBpr32" />
                    <MenuItem Header="48" x:Name="MenuBpr48" />
                    <MenuItem Header="64" x:Name="MenuBpr64" />
                </MenuItem>
                <MenuItem Header="CSV _Settings... (F8)" x:Name="MenuCsvSettings" HotKey="F8" IsVisible="False" />
                <Separator />
                <MenuItem Header="_Theme" x:Name="MenuTheme" />
                <MenuItem Header="_Font" x:Name="MenuFont">
                    <MenuItem Header="Select _Font..." x:Name="MenuSelectFont" />
                    <Separator />
                    <MenuItem Header="Font Size _+" x:Name="MenuFontSizeUp" />
                    <MenuItem Header="Font Size _-" x:Name="MenuFontSizeDown" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Navigate">
                <MenuItem Header="_Go to Offset/Line... (Ctrl+G)" x:Name="MenuGoto" HotKey="Ctrl+G" />
            </MenuItem>
            <MenuItem Header="_Search">
                <MenuItem Header="_Command Palette... (Ctrl+P)" x:Name="MenuCommandPalette" HotKey="Ctrl+P" />
                <Separator />
                <MenuItem Header="_Find... (Ctrl+F)" x:Name="MenuFind" HotKey="Ctrl+F" />
                <MenuItem Header="Find _Next (F3)" x:Name="MenuFindNext" HotKey="F3" />
                <MenuItem Header="Find _Previous (Shift+F3)" x:Name="MenuFindPrev" HotKey="Shift+F3" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Cu_t (Ctrl+X)" x:Name="MenuCut" HotKey="Ctrl+X" />
                <MenuItem Header="_Copy (Ctrl+C)" x:Name="MenuCopy" HotKey="Ctrl+C" />
                <MenuItem Header="_Paste (Ctrl+V)" x:Name="MenuPaste" HotKey="Ctrl+V" />
                <MenuItem Header="Select _All (Ctrl+A)" x:Name="MenuSelectAll" HotKey="Ctrl+A" />
                <MenuItem Header="_Delete Row(s)" x:Name="MenuDeleteRows" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Keyboard Shortcuts (F1)" x:Name="MenuKeyboardShortcuts" HotKey="F1" />
                <MenuItem Header="_About" x:Name="MenuAbout" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border x:Name="StatusBar" DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="4,2" Height="24">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                <!-- Col 0: File name (fills remaining) -->
                <TextBlock x:Name="SbFile" Text=" Leviathan" Grid.Column="0"
                           VerticalAlignment="Center" FontSize="12"
                           TextTrimming="None" />
                <!-- Col 1: separator -->
                <TextBlock Text="|" Grid.Column="1" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="6,0" />
                <!-- Col 2: background operations -->
                <TextBlock x:Name="SbBackground" Grid.Column="2" Width="108"
                           VerticalAlignment="Center" FontSize="12" TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <!-- Col 3: separator -->
                <TextBlock Text="|" Grid.Column="3" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="6,0" />
                <!-- Col 4: View mode -->
                <TextBlock x:Name="SbViewMode" Grid.Column="4" Width="44"
                           VerticalAlignment="Center" FontSize="12" TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <!-- Col 5: separator -->
                <TextBlock Text="|" Grid.Column="5" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="6,0" />
                <!-- Col 6: Encoding / Separator -->
                <TextBlock x:Name="SbEncoding" Grid.Column="6" Width="110"
                           VerticalAlignment="Center" FontSize="12" TextAlignment="Center"
                           TextTrimming="None" />
                <!-- Col 7: separator -->
                <TextBlock Text="|" Grid.Column="7" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="6,0" />
                <!-- Col 8: Position (offset / row,col) -->
                <TextBlock x:Name="SbPosition" Grid.Column="8" Width="180"
                           VerticalAlignment="Center" FontSize="12" TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <!-- Col 9: separator -->
                <TextBlock Text="|" Grid.Column="9" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="6,0" />
                <!-- Col 10: Lines/Rows -->
                <TextBlock x:Name="SbLines" Grid.Column="10" Width="220"
                           VerticalAlignment="Center" FontSize="12" TextAlignment="Center"
                           TextTrimming="None" />
                <!-- Col 11: separator -->
                <TextBlock Text="|" Grid.Column="11" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           Margin="6,0" />
                <!-- Col 12: File size -->
                <TextBlock x:Name="SbSize" Grid.Column="12" Width="88"
                           VerticalAlignment="Center" FontSize="12" TextAlignment="Right"
                           Margin="0,0,4,0" />
            </Grid>
        </Border>

        <!-- Content Area -->
        <Panel x:Name="ContentArea">
            <!-- Welcome Screen (visible when no file is open) -->
            <widgets:WelcomeScreen x:Name="WelcomeScreen" />
        </Panel>
    </DockPanel>

</Window>
