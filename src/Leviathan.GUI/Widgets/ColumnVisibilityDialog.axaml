<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Leviathan.GUI.Widgets.ColumnVisibilityDialog"
        x:CompileBindings="True"
        Title="Column Visibility"
        Width="340"
        Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        MinWidth="260"
        MinHeight="260">

    <DockPanel Margin="12">
        <!-- Search box -->
        <TextBox x:Name="SearchBox"
                 DockPanel.Dock="Top"
                 Watermark="Filter columns..."
                 Margin="0,0,0,8" />

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="ShowAllButton" Content="Show All" Width="80" />
            <Button x:Name="HideAllButton" Content="Hide All" Width="80" />
            <Button x:Name="CloseButton" Content="Close" Width="80" IsDefault="True" />
        </StackPanel>

        <!-- Column list with checkboxes -->
        <ListBox x:Name="ColumnList"
                 SelectionMode="Single" />
    </DockPanel>

</Window>
