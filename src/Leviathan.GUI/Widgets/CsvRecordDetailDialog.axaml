<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Leviathan.GUI.Widgets.CsvRecordDetailDialog"
        x:CompileBindings="True"
        Title="Record Detail"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel Margin="8">
        <TextBlock DockPanel.Dock="Top" x:Name="TitleText" FontWeight="SemiBold" FontSize="14"
                   Margin="8,4" />
        <Button DockPanel.Dock="Bottom" Content="Close" HorizontalAlignment="Right"
                Margin="8" x:Name="CloseButton" />
        <ScrollViewer>
            <StackPanel x:Name="FieldsPanel" Spacing="4" Margin="8" />
        </ScrollViewer>
    </DockPanel>

</Window>
