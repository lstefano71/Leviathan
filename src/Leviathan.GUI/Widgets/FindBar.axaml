<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Leviathan.GUI.Widgets.FindBar"
             x:CompileBindings="True"
             HorizontalAlignment="Right" VerticalAlignment="Top"
             Margin="8">

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            CornerRadius="4" Padding="8" BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox x:Name="SearchInput" Width="200" Watermark="Find..."
                     FontSize="13" />
            <CheckBox x:Name="CaseSensitiveCheck" Content="Aa" ToolTip.Tip="Case sensitive"
                      FontSize="11" VerticalAlignment="Center" />
            <CheckBox x:Name="HexModeCheck" Content="Hx" ToolTip.Tip="Hex pattern search"
                      FontSize="11" VerticalAlignment="Center" />
            <TextBlock x:Name="MatchStatus" Text="" VerticalAlignment="Center"
                       FontSize="12" Opacity="0.7" MinWidth="40" />
            <Button x:Name="PrevButton" Content="◀" FontSize="11" Width="28" Height="28"
                    ToolTip.Tip="Previous match (Shift+F3)" />
            <Button x:Name="NextButton" Content="▶" FontSize="11" Width="28" Height="28"
                    ToolTip.Tip="Next match (F3)" />
            <Button x:Name="CloseButton" Content="✕" FontSize="11" Width="28" Height="28"
                    ToolTip.Tip="Close (Esc)" />
        </StackPanel>
    </Border>

</UserControl>
