<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Leviathan.GUI.Widgets.WelcomeScreen"
             x:CompileBindings="True"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <!-- Two-column layout: file list (left) + info panel (right) -->
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
          Margin="24"
          ColumnDefinitions="*, 260">

        <!-- Left column: file list -->
        <Grid Grid.Column="0" Margin="0,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search Box -->
            <TextBox Grid.Row="0" x:Name="SearchInput" Watermark="Search recent files..."
                      FontSize="14" Margin="0,0,0,8" />

            <!-- Open File Action -->
            <Button Grid.Row="1" x:Name="OpenFileButton"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" Margin="0,0,0,4"
                    Background="Transparent" Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Open file..." FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Text="Ctrl+O" FontSize="12" Opacity="0.4"
                               VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
            </Button>

            <!-- File List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,4,0,8">
                <StackPanel x:Name="FileListPanel" Spacing="0" />
            </ScrollViewer>

            <!-- Hints -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="20"
                        HorizontalAlignment="Center" Opacity="0.4" Margin="0,8,0,0">
                <TextBlock Text="Ctrl+O  Open" FontSize="12" />
                <TextBlock Text="Ctrl+P  Palette" FontSize="12" />
                <TextBlock Text="Ctrl+Q  Quit" FontSize="12" />
            </StackPanel>
        </Grid>

        <!-- Right column: info panel -->
        <Border Grid.Column="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1,0,0,0" Padding="24,0,0,0">
            <StackPanel VerticalAlignment="Top" Spacing="20" Margin="0">

                <StackPanel Spacing="2">
                    <TextBlock Text="Leviathan" FontSize="24" FontWeight="Bold" Opacity="0.7" />
                    <TextBlock Text="Large File Editor" FontSize="13" Opacity="0.5" />
                </StackPanel>

                <!-- About section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="About" FontSize="13" FontWeight="SemiBold" Opacity="0.6" />
                    <TextBlock x:Name="InfoVersion" Text="Version 0.0.0" FontSize="12" Opacity="0.5" TextWrapping="Wrap" />
                    <TextBlock x:Name="InfoBuildDate" Text="" FontSize="12" Opacity="0.5" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Keyboard shortcuts section -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Shortcuts" FontSize="13" FontWeight="SemiBold" Opacity="0.6" />
                    <StackPanel Spacing="3">
                        <TextBlock Text="Ctrl+O     Open file" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="Ctrl+S     Save" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="Ctrl+F     Find" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="Ctrl+G     Go to" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="Ctrl+P     Palette" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="F5/F6/F7   Views" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="Ctrl+W     Close file" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                        <TextBlock Text="Ctrl+Q     Quit" FontSize="11" Opacity="0.45"
                                   FontFamily="Consolas, Courier New, monospace" />
                    </StackPanel>
                </StackPanel>

                <!-- Alt+N hint -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Quick open" FontSize="13" FontWeight="SemiBold" Opacity="0.6" />
                    <TextBlock Text="Alt+1…9 opens the&#10;corresponding file" FontSize="11"
                               Opacity="0.45" TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>

</UserControl>
